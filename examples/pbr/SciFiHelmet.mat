shader: "assets/shaders/default.vert" "assets/shaders/pbr.frag"
b useAlbedoTexture: true
b useNormalTexture: true
b useMetalnessTexture: true
b useRoughnessTexture: true
b useEmissiveTexture: false
b useAoTexture: true

bitmap albedoTexture: "assets/examples/SciFiHelmet/SciFiHelmet_BaseColor.png"
bitmap normalTexture: "assets/examples/SciFiHelmet/SciFiHelmet_Normal.png"
bitmap metalnessTexture: "assets/examples/SciFiHelmet/SciFiHelmet_MetallicRoughness.png"2
bitmap roughnessTexture: "assets/examples/SciFiHelmet/SciFiHelmet_MetallicRoughness.png"1
bitmap aoTexture: "assets/examples/SciFiHelmet/SciFiHelmet_AmbientOcclusion.png"

cubemap irradianceMap: _IRRADIANCE_MAP_
cubemap prefilterMap: _PREFILTER_MAP_
bitmap brdfLUT: _BRDF_LUT_